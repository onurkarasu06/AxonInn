@model AxonInn.Models.ErrorViewModel

@{
    Layout = null;
    
    // Model üzerinden gelen hata mesajını veya ID'sini alıyoruz
    var errorMsg = Model?.RequestId ?? "İşlem sırasında beklenmedik bir durum oluştu.";
    var errorTitle = "Sistem Hatası";
    var errorCode = "500"; // Genel sunucu hatası kodu
}


<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <title>@errorTitle - AxonInn</title>
    
    <link rel="preconnect" href="https://cdn.jsdelivr.net">
    <link rel="preconnect" href="https://cdnjs.cloudflare.com">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet">
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css">
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800&display=swap" rel="stylesheet">

    <style>
            body {
                background-color: #fbfcfe;
                font-family: 'Inter', sans-serif;
                min-height: 100dvh;
                margin: 0;
                display: flex;
                align-items: center;
                justify-content: center;
                overflow: hidden;
                padding: 20px;
                font-display: swap; /* Font yüklenene kadar sistem fontunu gösterir */
            }

            .error-card {
                background: white;
                border-radius: 2rem;
                padding: 3rem;
                box-shadow: 0 20px 40px rgba(0,0,0,0.05);
                max-width: 500px;
                width: 100%;
                text-align: center;
                border-bottom: 5px solid #dc3545 !important;
                animation: slideUp 0.5s ease-out forwards;
                will-change: transform, opacity; /* Animasyon performansını artırır */
            }

            .icon-box {
                width: 100px;
                height: 100px;
                margin: 0 auto 1.5rem;
                display: flex;
                align-items: center;
                justify-content: center;
                border-radius: 50%;
                background: rgba(220, 53, 69, 0.05);
                color: #dc3545;
                position: relative;
                border: 1px solid rgba(220, 53, 69, 0.1);
            }

            .transition-hover {
                transition: transform 0.3s ease, box-shadow 0.3s ease; /* All yerine spesifik geçiş atandı */
            }

            .transition-hover:hover {
                transform: translateY(-3px);
                box-shadow: 0 10px 20px rgba(0,0,0,0.1) !important;
            }

            @@keyframes slideUp {
                from { opacity: 0; transform: translateY(20px); }
                to { opacity: 1; transform: translateY(0); }
            }

            @@media (max-width: 576px) {
                .error-card { padding: 2.5rem 1.5rem; border-radius: 1.5rem; }
                .display-4 { font-size: 2.5rem; }
            }

            .error-card p { word-wrap: break-word; }
    </style>
</head>
<body>

    <div class="container d-flex align-items-center justify-content-center">
        <div class="w-100 d-flex justify-content-center">
            <div class="error-card shadow-lg">

                <div class="icon-box shadow-sm mx-auto mb-4">
                    <i class="fas fa-exclamation-triangle display-4"></i>
                    <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-danger">
                        @errorCode
                    </span>
                </div>

                <h1 class="h4 fw-bold text-dark mb-2">@errorTitle</h1>
                <p class="text-secondary small lh-base mb-4 px-1">
                    @errorMsg
                </p>

                <div class="px-md-4">
                    <a asp-controller="Error" asp-action="SafeLogout" class="btn btn-primary rounded-pill py-2 fw-bold shadow transition-hover w-100 d-inline-block text-decoration-none">
                        <i class="fas fa-sign-in-alt me-2"></i> GÜVENLİ ÇIKIŞ
                    </a>
                </div>

                <div class="mt-4 pt-3 border-top border-light-subtle opacity-75">
                    <div class="d-flex align-items-center justify-content-center">
                        <i class="fas fa-shield-alt text-muted me-2" style="font-size: 0.7rem;"></i>
                        <span style="font-size: 0.6rem; font-weight: 800; color: #6c757d; letter-spacing: 1px;" class="text-uppercase">
                            AxonInn Security Protocol
                        </span>
                    </div>
                </div>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
</body>
</html>
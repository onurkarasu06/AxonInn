@{
    ViewData["Title"] = "Gizlilik Politikası";
    Layout = "~/Views/Shared/_Layout.cshtml";
}

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />

<style>
    /* --- 1. SKELETON LOADER ANİMASYONU --- */
    .skeleton-box {
        display: inline-block;
        height: 1em;
        position: relative;
        overflow: hidden;
        background-color: #e2e5ec;
        border-radius: 8px;
    }

        .skeleton-box::after {
            position: absolute;
            top: 0;
            right: 0;
            bottom: 0;
            left: 0;
            transform: translateX(-100%);
            background-image: linear-gradient(90deg, rgba(255, 255, 255, 0) 0, rgba(255, 255, 255, 0.4) 20%, rgba(255, 255, 255, 0.6) 60%, rgba(255, 255, 255, 0));
            animation: shimmer 1.5s infinite;
            content: '';
        }
    @@keyframes shimmer {
        100% { transform: translateX(100%); }
    }

    /* --- 2. TEK EKRAN UYUMLULUK VE EFEKTLER --- */
    .compact-container {
        max-width: 850px;
        /* Tek ekrana sığması için yüksekliği menüden kalan alana göre ayarlar */
        min-height: calc(100vh - 100px);
        display: flex;
        flex-direction: column;
        justify-content: center;
    }

    .transition-hover {
        transition: all 0.3s ease;
    }

        .transition-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 8px 20px rgba(13, 110, 253, 0.08) !important;
        }

    .shadow-inner {
        box-shadow: inset 0 2px 4px rgba(0, 0, 0, 0.03) !important;
    }
</style>

<div id="skeletonLoader" class="container compact-container py-2">
    <div class="text-center mb-4">
        <div class="skeleton-box rounded-circle mb-2" style="width: 50px; height: 50px;"></div><br>
        <div class="skeleton-box mb-2" style="width: 200px; height: 28px; border-radius: 8px;"></div><br>
        <div class="skeleton-box w-50" style="height: 12px;"></div>
    </div>
    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                <div class="skeleton-box w-25 mb-3" style="height: 18px;"></div>
                <div class="skeleton-box w-100 mb-2" style="height: 10px;"></div>
                <div class="skeleton-box w-100 mb-2" style="height: 10px;"></div>
                <div class="skeleton-box w-100" style="height: 45px; border-radius: 8px;"></div>
            </div>
        </div>
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white">
                <div class="skeleton-box w-25 mb-3" style="height: 18px;"></div>
                <div class="skeleton-box w-100 mb-2" style="height: 10px;"></div>
                <div class="skeleton-box w-100" style="height: 10px;"></div>
            </div>
        </div>
    </div>
    <div class="text-center mt-4">
        <div class="skeleton-box w-25" style="height: 8px;"></div>
    </div>
</div>

<div id="mainContent" class="container compact-container py-2 d-none animate__animated animate__fadeIn" style="font-family: 'Inter', sans-serif;">

    <div class="text-center mb-4 animate__animated animate__fadeInDown">
        <div class="d-inline-flex align-items-center justify-content-center bg-primary bg-opacity-10 text-primary rounded-circle mb-2 shadow-sm"
             style="width: 55px; height: 55px; border: 2px solid rgba(13, 110, 253, 0.05);">
            <svg xmlns="http://www.w3.org/2000/svg" width="24" height="24" fill="currentColor" class="bi bi-shield-check" viewBox="0 0 16 16">
                <path d="M8 14.933a.6.6 0 0 1-.1-.063C6.7 14.1 4.4 12.3 2.5 8.7c-.7-1.3-1-2.4-1-3.4V2.5A.5.5 0 0 1 2 2h12a.5.5 0 0 1 .5.5v2.8c0 1-.3 2.1-1 3.4-1.9 3.6-4.2 5.4-5.4 6.2a.6.6 0 0 1-.1.063zM1.5 5.3c0 1.2.4 2.4 1 3.4 1.8 3.3 3.8 5 5 5.7 1.2-.7 3.2-2.4 5-5.7.6-1 1-2.2 1-3.4V2.5h-11v2.8z" />
                <path d="M10.854 6.146a.5.5 0 0 1 0 .708l-3 3a.5.5 0 0 1-.708 0l-1.5-1.5a.5.5 0 1 1 .708-.708L7.5 8.793l2.646-2.647a.5.5 0 0 1 .708 0z" />
            </svg>
        </div>
        <h1 class="fw-bolder text-dark h4 mb-1" style="letter-spacing: -0.5px;">Gizlilik Politikası</h1>
        <p class="text-secondary mb-0 mx-auto" style="max-width: 450px; font-size: 0.8rem;">
            Verileriniz <span class="text-primary fw-bold">AxonInn</span> altyapısı ile global güvenlik standartlarında korunmaktadır.
        </p>
    </div>

    <div class="row g-3">
        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-bottom border-primary border-3 transition-hover">
                <h3 class="h6 fw-bold text-dark border-start border-primary border-4 ps-2 mb-2 text-uppercase" style="letter-spacing: 0.5px; font-size: 0.7rem;">Veri Toplama ve Kullanım</h3>
                <p class="text-muted mb-3" style="font-size: 0.8rem; line-height: 1.6;">
                    AxonInn olarak, otel operasyonlarınızı kolaylaştırmak adına topladığımız veriler sadece sistemin işleyişi ve size daha iyi hizmet sunmak amacıyla kullanılır. Kişisel verileriniz asla reklam veya pazarlama amaçlı üçüncü taraflarla paylaşılmaz.
                </p>
                <div class="bg-light rounded-3 p-2 border border-light-subtle shadow-inner">
                    <ul class="list-unstyled mb-0 text-secondary d-flex flex-wrap justify-content-center justify-content-sm-start gap-3" style="font-size: 0.75rem;">
                        <li class="d-flex align-items-center"><i class="fas fa-lock text-success me-1"></i> 256-bit SSL</li>
                        <li class="d-flex align-items-center"><i class="fas fa-server text-success me-1"></i> Günlük Yedekleme</li>
                        <li class="d-flex align-items-center"><i class="fas fa-user-shield text-success me-1"></i> KVKK Uyumlu</li>
                    </ul>
                </div>
            </div>
        </div>

        <div class="col-12">
            <div class="card border-0 shadow-sm rounded-4 p-3 bg-white border-bottom border-primary border-3 transition-hover">
                <h3 class="h6 fw-bold text-dark border-start border-primary border-4 ps-2 mb-2 text-uppercase" style="letter-spacing: 0.5px; font-size: 0.7rem;">Güvenlik ve Çerezler</h3>
                <p class="text-muted mb-0" style="font-size: 0.8rem; line-height: 1.6;">
                    Sistem performansını artırmak için sadece gerekli teknik çerezler kullanılmaktadır. Reklam veya takip amaçlı üçüncü taraf çerezleri sistemimizde yer almaz. Güvenliğiniz için tüm oturumlar kriptolanmış tokenlar ile yönetilir.
                </p>
            </div>
        </div>
    </div>

    <div class="text-center mt-4 opacity-50">
        <hr class="w-25 mx-auto mb-2 border-secondary">
        <p style="font-size: 0.6rem; letter-spacing: 0.5px; font-weight: 600;" class="text-uppercase mb-0">
            AxonInn Güvenlik Protokolü v2.0
        </p>
    </div>
</div>

@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            // 400 milisaniye iskelet görünümü (sayfalar arası akıcı geçiş hissi için)
            setTimeout(function() {
                const loader = document.getElementById('skeletonLoader');
                if(loader) loader.classList.add('d-none');

                const mainContent = document.getElementById('mainContent');
                if(mainContent) mainContent.classList.remove('d-none');
            }, 400);
        });
    </script>
}
<script src="https://cdn.jsdelivr.net/npm/sweetalert2@11" defer></script>

<script>
    // DEĞİŞİKLİK: Tüm jQuery ($) fonksiyonları saf JavaScript'e çevrildi
    document.addEventListener("DOMContentLoaded", function () {
        setTimeout(function() {
            const loader = document.getElementById('skeletonLoader');
            if(loader) loader.classList.add('d-none');
            const mainContent = document.getElementById('mainContent');
            if(mainContent) mainContent.classList.remove('d-none');
        }, 50);

        document.querySelectorAll('form').forEach(form => {
            form.addEventListener('submit', function () {
                const submitBtn = this.querySelector('button[type="submit"]');
                if (submitBtn) {
                    const textSpan = submitBtn.querySelector('.btn-text');
                    const spinner = submitBtn.querySelector('.btn-spinner');
                    submitBtn.classList.add('btn-loading');
                    if(textSpan && spinner) {
                        textSpan.innerText = 'İşleniyor...';
                        spinner.classList.remove('d-none');
                    }
                }
            });
        });

        // Event Listener'lar
        document.getElementById("tabloAra").addEventListener("keyup", tabloyuFiltrele);

        document.querySelectorAll('.durum-filter-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                document.querySelectorAll('.durum-filter-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
                document.getElementById('selectedDurumText').innerText = this.innerText;
                currentDurum = this.getAttribute('data-value');
                tabloyuFiltrele();
            });
        });

        document.querySelectorAll('.dept-filter-item').forEach(item => {
            item.addEventListener('click', function(e) {
                e.preventDefault();
                document.querySelectorAll('.dept-filter-item').forEach(i => i.classList.remove('active'));
                this.classList.add('active');
                document.getElementById('selectedDeptText').innerText = this.innerText;
                currentDept = this.getAttribute('data-value'); 
                tabloyuFiltrele();
            });
        });
    });

    let currentDurum = "";
    let currentDept = "";

    function tabloyuFiltrele() {
        var arama = document.getElementById("tabloAra").value.toLocaleLowerCase('tr-TR');
        var trs = document.querySelectorAll("#gorevTablosu tbody tr");
        
        trs.forEach(function(tr) {
            var metin = tr.innerText.toLocaleLowerCase('tr-TR');
            var searchDurum = currentDurum.toLocaleLowerCase('tr-TR');
            var searchDept = currentDept.toLocaleLowerCase('tr-TR');

            var metinVar = arama === "" || metin.includes(arama);
            var durumVar = searchDurum === "" || metin.includes(searchDurum);
            var depVar = searchDept === "" || metin.includes(searchDept);

            if (metinVar && durumVar && depVar) {
                tr.style.display = "";
            } else {
                tr.style.display = "none";
            }
        });
    }

    function prepareEdit(id, pId, aciklama, not, durum) {
        document.getElementById('editGorevID').value = id;
        document.getElementById('editPersonelID').value = pId;
        document.getElementById('editGorevAciklama').value = aciklama;
        document.getElementById('editGorevNotu').value = (not === 'null' || not === null) ? '' : not;
        document.getElementById('editGorevDurumu').value = durum;
    }

    function openDetayModal(aciklama, not) {
        document.getElementById('detayGorevAciklama').innerText = aciklama;
        const notBolumu = document.getElementById('notBolumu');
        if (not && not !== 'null' && not.trim() !== '') {
            document.getElementById('detayGorevNotu').innerText = not;
            notBolumu.style.display = 'block';
        } else {
            notBolumu.style.display = 'none';
        }
    }

    function prepareDelete(gorevId, adSoyad) {
        document.getElementById('silFormu').setAttribute('action', '/Gorev/Sil?id=' + gorevId);
        document.getElementById('gorevSilModalIsim').innerText = adSoyad;
        const tabloFoto = document.getElementById('tabloFoto_' + gorevId);
        const modalIcon = document.getElementById('gorevSilModalDefaultIcon');
        const modalImg = document.getElementById('gorevSilModalFoto');
        if (tabloFoto && modalImg && modalIcon) {
            modalImg.src = tabloFoto.src;
            modalImg.style.display = 'block';
            modalIcon.style.display = 'none';
        } else if (modalImg && modalIcon) {
            modalImg.src = '';
            modalImg.style.display = 'none';
            modalIcon.style.display = 'block';
        }
    }

    function personelFotoGoster(resimData, tamAd) {
        const resim = document.getElementById('modalPersonelResim');
        const isim = document.getElementById('modalPersonelIsim');
        if(resim && isim) {
            resim.src = resimData;
            isim.innerText = tamAd;
            new bootstrap.Modal(document.getElementById('merkeziPersonelFotoModal')).show();
        }
    }

    function kanitFotografGoster(fotoIdListesi) {
        const icerikContainer = document.getElementById('carouselIcerik');
        if(!icerikContainer) return;
        icerikContainer.innerHTML = '';
        fotoIdListesi.forEach((fotoId, index) => {
            const activeClass = index === 0 ? 'active' : '';
            icerikContainer.insertAdjacentHTML('beforeend',
                `<div class="carousel-item ${activeClass}">
                    <img src="/Gorev/KanitFotoGetir?id=${fotoId}" class="d-block w-100" loading="lazy">
                </div>`
            );
        });
        new bootstrap.Modal(document.getElementById('merkeziKanitModal')).show();
    }

    function yeniGorevPersonelFiltrele(selectElement) {
        var secilenDept = selectElement.value;
        var personelSelect = document.querySelector('.modal-pers-select');
        personelSelect.value = "";
        
        var options = personelSelect.querySelectorAll('.pers-item');
        options.forEach(opt => {
            if (secilenDept === "all") {
                opt.style.display = "";
                opt.disabled = false;
            } else {
                if(opt.classList.contains(secilenDept)) {
                    opt.style.display = "";
                    opt.disabled = false;
                } else {
                    opt.style.display = "none";
                    opt.disabled = true;
                }
            }
        });
    }

    function guncellePersonelFiltrele(selectElement) {
        var secilenDept = selectElement.value;
        var personelSelect = document.querySelector('.edit-pers-select');
        var options = personelSelect.querySelectorAll('.edit-pers-item');
        var ilkUygun = null;
        
        options.forEach(opt => {
            if (secilenDept === "all") {
                opt.style.display = "";
                opt.disabled = false;
            } else {
                if(opt.classList.contains(secilenDept)) {
                    opt.style.display = "";
                    opt.disabled = false;
                    if(!ilkUygun) ilkUygun = opt;
                } else {
                    opt.style.display = "none";
                    opt.disabled = true;
                }
            }
        });
        
        var selectedOpt = personelSelect.options[personelSelect.selectedIndex];
        if (secilenDept !== "all" && selectedOpt && selectedOpt.style.display === "none" && ilkUygun) {
            personelSelect.value = ilkUygun.value;
        }
    }
</script>

@if (TempData["Mesaj"] != null)
{
    <script>
        document.addEventListener("DOMContentLoaded", function () {
            setTimeout(() => {
                if (typeof Swal !== 'undefined') {
                    Swal.fire({
                        icon: '@(TempData["MesajTipi"] ?? "warning")',
                        title: 'Bilgilendirme',
                        text: '@Html.Raw(TempData["Mesaj"])',
                        confirmButtonText: 'Tamam',
                        confirmButtonColor: '#0d6efd',
                        customClass: { confirmButton: 'rounded-pill px-4' }
                    });
                }
            }, 100);
        });
    </script>
}
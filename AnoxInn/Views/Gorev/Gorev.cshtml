@model AxonInn.Models.Hotel
@using Microsoft.AspNetCore.Http
@using System.Text.Encodings.Web

@{
    Layout = "~/Views/Shared/_Layout.cshtml";
    
    var girisYapanPersonel = ViewData["GirisYapanPersonel"] as AxonInn.Models.Personel;
    int yetki = girisYapanPersonel?.Yetki ?? 0;
    
    var departmanlar = Model?.Departmen ?? Enumerable.Empty<AxonInn.Models.Departman>();
    var personelList = departmanlar.SelectMany(d => d.Personels);
    var gorevList = personelList.SelectMany(p => p.Gorevs).OrderByDescending(g => g.KayitTarihi);
}

<script> 
  gtag('event', 'conversion', {'send_to': 'AW-18020925402/73hECN6-9okcENr_hZFD'}); 
</script>

<link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" media="print" onload="this.media='all'" />
<link rel="stylesheet" href="https://cdn.datatables.net/1.13.6/css/dataTables.bootstrap5.min.css">
<noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" /></noscript>

<style>
    /* Kaydırma Çubuğu Optimizasyonu */
    .table-responsive::-webkit-scrollbar { width: 6px; height: 6px; }
    .table-responsive::-webkit-scrollbar-track { background: #f8fafc; border-radius: 10px; }
    .table-responsive::-webkit-scrollbar-thumb { background: #cbd5e1; border-radius: 10px; }
    .table-responsive::-webkit-scrollbar-thumb:hover { background: #94a3b8; }
    .table-responsive { border-radius: 12px; -webkit-overflow-scrolling: touch; }
    
    /* Avatarlar ve Resimler */
    .avatar-container { position: relative; width: 42px; height: 42px; display: inline-block; }
    .avatar-img { width: 42px; height: 42px; object-fit: cover; object-position: top; transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275); background-color: #f8f9fa; border: 2px solid #fff; box-shadow: 0 2px 5px rgba(0,0,0,0.05); }
    .avatar-container:hover .avatar-img { transform: scale(2.2); z-index: 100; position: relative; box-shadow: 0 10px 25px rgba(0,0,0,0.15) !important; border-color: #fff; }
    
    .kanit-img { width: 50px; height: 50px; object-fit: cover; border-radius: 10px; transition: transform 0.3s ease; cursor: zoom-in; box-shadow: 0 2px 5px rgba(0,0,0,0.08); }
    .kanit-container { transition: transform 0.3s ease; z-index: 1; }
    .kanit-container:hover { transform: scale(2.2); z-index: 999; position: relative; }
    
    .personel-foto-tikla { cursor: pointer; transition: filter 0.3s ease; }
    .personel-foto-tikla:hover { filter: brightness(0.85); }
    
    /* İşlem Butonları (Gölgeli ve hover efektli) */
    .btn-edit-small { width: 36px; height: 36px; padding: 0; display: inline-flex; align-items: center; justify-content: center; border-radius: 10px; border: 1px solid transparent; transition: all 0.2s ease; background-color: #f8f9fa;}
    .btn-edit-small:hover { transform: translateY(-2px); box-shadow: 0 4px 8px rgba(0,0,0,0.1); }
    .btn-edit-small.btn-outline-primary { border-color: rgba(13, 110, 253, 0.2); color: #0d6efd; background-color: rgba(13, 110, 253, 0.05); }
    .btn-edit-small.btn-outline-primary:hover { background-color: #0d6efd; color: #fff; }
    .btn-edit-small.btn-outline-danger { border-color: rgba(220, 53, 69, 0.2); color: #dc3545; background-color: rgba(220, 53, 69, 0.05); }
    .btn-edit-small.btn-outline-danger:hover { background-color: #dc3545; color: #fff; }
    
    .gorev-link { font-family: 'Inter', sans-serif; font-size: 0.9rem; cursor: pointer; color: #334155; font-weight: 600; text-decoration: none; transition: color 0.2s ease; line-height: 1.4; display: inline-block; }
    .gorev-link:hover { color: #5c7cfa !important; }
    
    button:disabled { cursor: not-allowed !important; opacity: 0.6; }
    .btn-loading { opacity: 0.8 !important; pointer-events: none !important; cursor: not-allowed !important; }
    
    /* Filtre ve Arama Alanları Hover */
    .custom-filter-btn { background: #fff; transition: all 0.2s; }
    .custom-filter-btn:hover { background: #f8fafc; }
    
    /* Tablo Satır Efekti */
    .gorev-satiri { transition: background-color 0.2s ease; }
    .gorev-satiri:hover { background-color: #f8faff !important; }
    
    /* Modallar */
    #merkeziPersonelFotoModal .modal-content { background: transparent; border: none; }
    .personel-modal-wrapper { position: relative; display: inline-flex; flex-direction: column; align-items: center; margin: auto; width: 280px; }
    .personel-büyük-foto { width: 280px; height: 280px; border: 8px solid white; border-radius: 30px; box-shadow: 0 20px 40px rgba(0,0,0,0.25); object-fit: cover; object-position: top; background-color: #f8f9fa; display: block; }
    .modal-isim-etiket { margin-top: -15px; z-index: 5; background: linear-gradient(135deg, #5c7cfa 0%, #3b5bdb 100%); color: white; padding: 10px 24px; border-radius: 20px; font-weight: 600; font-size: 0.9rem; border: 3px solid white; box-shadow: 0 8px 15px rgba(92, 124, 250, 0.3); letter-spacing: 0.5px; }
    .delete-modal-avatar { width: 100% !important; height: 100% !important; border-radius: 50%; object-fit: cover !important; object-position: top !important; background-color: #f8f9fa; }
    
    .kanit-modal-cerceve { border: 6px solid #ffffff; border-radius: 20px; background-color: #ffffff; position: relative; display: inline-block; max-width: 95vw; box-shadow: 0 20px 40px rgba(0,0,0,0.2); }
    .modal-kapat-cerceve-kanit, .modal-kapat-cerceve-yeni { position: absolute; top: -15px; right: -15px; z-index: 1100; background-color: #ef4444; width: 36px; height: 36px; display: flex; align-items: center; justify-content: center; border-radius: 50%; border: 3px solid #ffffff; box-shadow: 0 4px 12px rgba(239, 68, 68, 0.4); cursor: pointer; transition: all 0.2s ease; }
    .modal-kapat-cerceve-kanit:hover, .modal-kapat-cerceve-yeni:hover { transform: scale(1.1); background-color: #dc2626; }
    
    #carouselIcerik img { max-height: 75vh; max-width: 100%; border-radius: 12px; object-fit: contain; }
    
    /* Skeleton Loader Düzenlemesi */
    .skeleton-box { display: inline-block; height: 1em; position: relative; overflow: hidden; background-color: #e2e8f0; border-radius: 8px; }
    .skeleton-box::after { position: absolute; top: 0; right: 0; bottom: 0; left: 0; transform: translateX(-100%); background-image: linear-gradient(90deg, rgba(255, 255, 255, 0) 0, rgba(255, 255, 255, 0.4) 20%, rgba(255, 255, 255, 0.6) 60%, rgba(255, 255, 255, 0)); animation: shimmer 1.5s infinite; content: ''; }
    
    @@keyframes shimmer { 100% { transform: translateX(100%); } }
    
    @@media (max-width: 768px) { 
        .container-fluid { padding-left: 15px; padding-right: 15px; } 
        h6.text-uppercase { font-size: 0.7rem !important; letter-spacing: 2px !important; } 
        h5.fw-bold { font-size: 1.15rem; margin-bottom: 10px !important; } 
        .table thead th { font-size: 0.65rem !important; padding: 12px 8px !important; } 
        .table tbody td { padding: 12px 8px !important; font-size: 0.8rem !important; } 
        .avatar-container, .avatar-img { width: 32px; height: 32px; } 
        .gorev-link { font-size: 0.85rem !important; display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden; white-space: normal; } 
        .btn-edit-small { width: 34px; height: 34px; } 
        .modal-dialog { margin: auto !important; display: flex !important; align-items: center !important; justify-content: center !important; min-height: calc(100% - 1rem); } 
        .modal-content { max-width: 90vw !important; margin: 0 auto !important; } 
        .personel-modal-wrapper { width: 100% !important; max-width: 280px; display: flex; flex-direction: column; align-items: center; } 
        .personel-büyük-foto { max-width: 100%; height: auto; aspect-ratio: 1/1; border-radius: 25px; } 
        .kanit-modal-cerceve { border-width: 4px; } 
        .modal-kapat-cerceve-kanit, .modal-kapat-cerceve-yeni { top: -10px; right: -10px; width: 30px; height: 30px; } 
    }
</style>

<div id="skeletonLoader" class="container-fluid mt-4">
    <div class="skeleton-box w-100 mb-4" style="height: 48px; border-radius: 12px;"></div>
    <div class="row mb-4 align-items-center">
        <div class="col-6">
            <div class="skeleton-box w-50" style="height: 35px;"></div>
        </div>
        <div class="col-6 text-end">
            <div class="skeleton-box w-25 rounded-pill" style="height: 40px;"></div>
        </div>
    </div>
    <div class="row mb-4 g-4">
        <div class="col-md-4"><div class="skeleton-box w-100" style="height: 45px; border-radius: 10px;"></div></div>
        <div class="col-md-4"><div class="skeleton-box w-100" style="height: 45px; border-radius: 10px;"></div></div>
        <div class="col-md-4"><div class="skeleton-box w-100" style="height: 45px; border-radius: 10px;"></div></div>
    </div>
    <div class="card border-0 shadow-sm rounded-4 overflow-hidden" style="border: 1px solid rgba(0,0,0,0.05);">
        <div class="card-body p-0">
            <div class="p-4 bg-light border-bottom d-flex justify-content-between">
                <div class="skeleton-box w-100" style="height: 20px;"></div>
            </div>
            <div class="p-4">
                @for (int i = 0; i < 5; i++)
                {
                    <div class="d-flex align-items-center justify-content-between mb-4 border-bottom pb-4">
                        <div class="skeleton-box rounded-circle me-3" style="width: 40px; height: 40px;"></div>
                        <div class="skeleton-box" style="width: 20%; height: 20px;"></div>
                        <div class="skeleton-box" style="width: 30%; height: 20px;"></div>
                        <div class="skeleton-box" style="width: 10%; height: 20px;"></div>
                        <div class="skeleton-box" style="width: 15%; height: 20px;"></div>
                        <div class="skeleton-box" style="width: 10%; height: 35px; border-radius: 8px;"></div>
                    </div>
                }
            </div>
        </div>
    </div>
</div>

<div id="mainContent" class="container-fluid d-none animate__animated animate__fadeIn mt-3 mb-5">
    
    <div class="row mb-4">
        <div class="col-12">
            <div class="d-flex align-items-center justify-content-center shadow-sm w-100 py-3" style="background-color: #f8faff; border-radius: 12px; border: 1px solid rgba(92, 124, 250, 0.1);">
                <h6 class="mb-0 text-uppercase fw-bold" style="letter-spacing: 4px; color: #5c7cfa; font-size: 0.8rem;">
                    <i class="fas fa-hotel me-2 opacity-75"></i>
                    @(Model?.Adi ?? "AxonInn Otel")
                </h6>
            </div>
        </div>
    </div>

    <div class="row mb-4 align-items-center">
        <div class="col-8 col-md-6">
            <h4 class="fw-bolder text-dark mb-0"><i class="fas fa-tasks me-2 text-primary opacity-75"></i>Görev Yönetimi</h4>
        </div>
        <div class="col-4 col-md-6 text-end">
            @if (yetki == 1)
            {
                <button type="button" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-semibold" data-bs-toggle="modal" data-bs-target="#yeniGorevModal">
                    <i class="fas fa-plus me-1"></i>
                    <span class="d-none d-md-inline ms-1">Yeni Görev</span>
                    <span class="d-inline d-md-none">Ekle</span>
                </button>
            }
            else
            {
                <button type="button" class="btn btn-primary rounded-pill px-4 py-2 shadow-sm fw-semibold opacity-50" disabled title="Ekleme yetkiniz yok">
                    <i class="fas fa-plus me-1"></i>
                    <span class="d-none d-md-inline ms-1">Yeni Görev</span>
                    <span class="d-inline d-md-none">Ekle</span>
                </button>
            }
        </div>
    </div>

    <div class="row mb-4 g-4 align-items-stretch">
        <div class="col-md-4">
            <div class="input-group shadow-sm rounded-3 overflow-hidden border bg-white h-100">
                <span class="input-group-text bg-transparent border-0 ps-3">
                    <i class="fas fa-search text-muted opacity-50"></i>
                </span>
                <input type="text" id="tabloAra" class="form-control border-0 shadow-none py-2 px-2" placeholder="Personel veya görev ara..." />
            </div>
        </div>

        <div class="col-md-4">
            <div class="dropdown custom-filter-dropdown w-100 h-100">
                <button class="btn custom-filter-btn border shadow-sm rounded-3 w-100 h-100 py-2 px-3 d-flex align-items-center justify-content-between" type="button" id="durumFilterBtn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="text-truncate">
                        <i class="fas fa-filter text-primary me-2 opacity-75"></i>
                        <span id="selectedDurumText" class="text-dark fw-medium">Tüm Durumlar</span>
                    </span>
                    <i class="fas fa-chevron-down small text-muted ms-2"></i>
                </button>
                <ul class="dropdown-menu border-0 shadow-lg py-2 animate-slide-in w-100" aria-labelledby="durumFilterBtn" style="border-radius: 12px; border: 1px solid #f1f5f9;">
                    <li><a class="dropdown-item active durum-filter-item rounded-2 mb-1" href="#" data-value="">Tüm Durumlar</a></li>
                    <li><a class="dropdown-item durum-filter-item rounded-2 mb-1" href="#" data-value="1">🔴 Beklemede</a></li>
                    <li><a class="dropdown-item durum-filter-item rounded-2 mb-1" href="#" data-value="2">🟡 İşlemde</a></li>
                    <li><a class="dropdown-item durum-filter-item rounded-2" href="#" data-value="3">🟢 Tamamlandı</a></li>
                </ul>
            </div>
        </div>

        <div class="col-md-4">
            <div class="dropdown custom-filter-dropdown w-100 h-100">
                <button class="btn custom-filter-btn border shadow-sm rounded-3 w-100 h-100 py-2 px-3 d-flex align-items-center justify-content-between" type="button" id="deptFilterBtn" data-bs-toggle="dropdown" aria-expanded="false">
                    <span class="text-truncate">
                        <i class="fas fa-building text-primary me-2 opacity-75"></i>
                        <span id="selectedDeptText" class="text-dark fw-medium">Tüm Departmanlar</span>
                    </span>
                    <i class="fas fa-chevron-down small text-muted ms-2"></i>
                </button>
                <ul class="dropdown-menu border-0 shadow-lg py-2 animate-slide-in w-100" aria-labelledby="deptFilterBtn" style="border-radius: 12px; max-height: 250px; overflow-y: auto; border: 1px solid #f1f5f9;">
                    <li><a class="dropdown-item active dept-filter-item rounded-2 mb-1" href="#" data-value="">Tüm Departmanlar</a></li>
                    @foreach (var dep in departmanlar)
                    {
                        <li><a class="dropdown-item dept-filter-item rounded-2 mb-1" href="#" data-value="@dep.Adi.ToLowerInvariant()">@dep.Adi</a></li>
                    }
                </ul>
            </div>
        </div>
    </div>

    <div class="card border-0 shadow-sm rounded-4 overflow-hidden mb-5" style="border: 1px solid rgba(0,0,0,0.05) !important;">
        <div class="card-body p-0">
            <div class="table-responsive" style="max-height: 600px; overflow-y: auto;">
                <table class="table table-hover align-middle mb-0" id="gorevTablosu" style="width:100%">
                    <thead class="bg-light sticky-top shadow-sm" style="z-index: 10;">
                        <tr class="text-uppercase fw-bold text-secondary" style="font-size: 0.75rem; letter-spacing: 0.5px;">
                            <th class="ps-4 py-3 border-bottom-0">PERSONEL</th>
                            <th class="py-3 border-bottom-0">AÇIKLAMA</th>
                            <th class="py-3 text-center border-bottom-0">İŞ DURUMU</th>
                            <th class="py-3 border-bottom-0">KAYIT BİLGİSİ</th>
                            <th class="py-3 text-center border-bottom-0">FOTOĞRAF</th>
                            <th class="py-3 text-center border-bottom-0 pe-4">İŞLEM</th>
                        </tr>
                    </thead>
                    <tbody class="border-top-0">
                        @foreach (var item in gorevList)
                        {
                            var tamAd = $"{item.PersonelRefNavigation?.Adi} {item.PersonelRefNavigation?.Soyadi}";
                            var departmanAdi = item.PersonelRefNavigation?.DepartmanRefNavigation?.Adi;

                            // ⚡ DÜZELTME: Arama için Türkçe metin verisi geri eklendi
                            var aramaData = $"{tamAd} {item.Aciklama} {departmanAdi}".ToLowerInvariant();

                            <tr class="gorev-satiri bg-white border-bottom" data-search="@aramaData" data-durum="@item.Durum" data-dept="@(departmanAdi?.ToLowerInvariant() ?? "")">
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div class="me-3 avatar-container shadow-sm rounded-circle btn-personel-foto" data-isim="@tamAd" data-src="@Url.Action("PersonelFotoGetir", "Gorev", new { id = item.PersonelRef })">
                                            <img id="tabloFoto_@item.Id" 
                                                 src="@Url.Action("PersonelFotoGetir", "Gorev", new { id = item.PersonelRef })"
                                                 class="rounded-circle avatar-img personel-foto-tikla" 
                                                 loading="lazy" decoding="async"
                                                 onerror="this.style.display='none'; this.nextElementSibling.style.display='flex';"
                                                 title="Büyütmek için tıkla" />
                                            
                                            <div class="bg-primary bg-opacity-10 text-primary rounded-circle align-items-center justify-content-center fw-bold avatar-img" style="font-size: 0.9rem; display: none;">
                                                @(item.PersonelRefNavigation?.Adi?[0])@(item.PersonelRefNavigation?.Soyadi?[0])
                                            </div>
                                        </div>
                                        <div>
                                            <div class="fw-bold text-dark mb-1" style="font-size: 0.9rem;">@tamAd</div>
                                            <small class="text-muted fw-medium bg-light px-2 py-1 rounded" style="font-size: 0.75rem;">@departmanAdi</small>
                                        </div>
                                    </div>
                                </td>

                                <td style="max-width: 220px;">
                                    <div class="gorev-link fw-semibold text-dark text-truncate w-100 btn-detay-goster"
                                         data-bs-toggle="modal" data-bs-target="#detayModal"
                                         data-aciklama="@item.Aciklama"
                                         data-not="@item.PersonelNotu"
                                         title="Detayları gör">
                                        <i class="fas fa-external-link-alt me-1 small opacity-50"></i>
                                        @item.Aciklama
                                    </div>
                                    @if (!string.IsNullOrEmpty(item.PersonelNotu))
                                    {
                                        <div class="mt-1 opacity-50" style="font-size: 0.6rem;">
                                            <span class="text-muted fw-normal" style="font-style: italic;">(Personel notu mevcut)</span>
                                        </div>
                                    }
                                </td>

                                <td class="text-center py-3">
                                     @switch (item.Durum)
                                    {
                                        case 1:
                                            <span class="text-danger fw-bold"><i class="fas fa-circle me-1 small opacity-50"></i> Beklemede</span>
                                            break;
                                        case 2:
                                            <span class="text-warning fw-bold"><i class="fas fa-spinner fa-spin me-1"></i> İşlemde</span>
                                            break;
                                        case 3:
                                            <span class="text-success fw-bold"><i class="fas fa-check-circle me-1"></i> Tamamlandı</span>
                                            break;
                                    }
                                </td>

                                <td class="py-3">
                                    @{ 
                                        string statusColor = item.Durum switch { 1 => "text-danger", 2 => "text-warning", 3 => "text-success", _ => "text-secondary" };
                                    }
                                    <div class="d-flex flex-column gap-2" style="font-size: 0.75rem;">
                                        <div class="d-flex align-items-center text-secondary">
                                            <i class="far fa-plus-square me-2 opacity-75" style="width: 14px;"></i>
                                            <span>Kayıt: <span class="text-dark fw-medium">@item.KayitTarihi.ToString("dd.MM.yy HH:mm")</span></span>
                                        </div>
                                        <div class="d-flex align-items-center text-secondary">
                                            <i class="far fa-play-circle me-2 opacity-75" style="width: 14px;"></i>
                                            <span>Başlama: @(item.CozumBaslamaTarihi?.ToString("dd.MM.yy HH:mm") ?? "--:--")</span>
                                        </div>
                                        <div class="d-flex align-items-center @statusColor">
                                            <i class="far fa-check-square me-2" style="width: 14px;"></i>
                                            <span class="@(item.CozumBitisTarihi.HasValue ? "fw-bold" : "")">
                                                Bitiş: @(item.CozumBitisTarihi?.ToString("dd.MM.yy HH:mm") ?? "--:--")
                                            </span>
                                        </div>
                                    </div>
                                </td>

                                <td class="text-center py-3">
                                    @if (item.GorevFotografs != null && item.GorevFotografs.Any())
                                    {
                                        var fotoIds = string.Join(",", item.GorevFotografs.Select(f => f.Id));
                                        <div class="kanit-container position-relative btn-kanit-goster" data-fotolar="@fotoIds" style="cursor: pointer;">
                                            <img src="/Gorev/KanitFotoGetir?id=@item.GorevFotografs.First().Id" loading="lazy" decoding="async" class="shadow-sm border border-2 border-white kanit-img bg-light" />
                                            @if (item.GorevFotografs.Count > 1)
                                            {
                                                <span class="position-absolute top-0 start-100 translate-middle badge rounded-pill bg-dark border border-2 border-white shadow-sm" style="font-size: 0.65rem; padding: 0.35em 0.5em;">+@(item.GorevFotografs.Count - 1)</span>
                                            }
                                        </div>
                                    }
                                    else
                                    {
                                        <span class="text-muted small opacity-50"><i class="fas fa-minus"></i></span>
                                    }
                                </td>

                                <td class="text-center">
                                    <div class="btn-group gap-1">
                                        @if (yetki <= 2)
                                        {
                                            <button class="btn btn-outline-primary btn-edit-small btn-gorev-duzenle" 
                                                    data-bs-toggle="modal" data-bs-target="#guncelleModal"
                                                    data-id="@item.Id" data-pid="@item.PersonelRef" 
                                                    data-aciklama="@item.Aciklama" data-not="@item.PersonelNotu" data-durum="@item.Durum">
                                                <i class="fas fa-pencil-alt"></i>
                                            </button>
                                        }
                                        else if (yetki == 3)
                                        {
                                            <button class="btn btn-outline-primary btn-edit-small opacity-50" disabled title="Düzenleme yetkisi yok"><i class="fas fa-pencil-alt"></i></button>
                                        }

                                        @if (yetki == 1)
                                        {
                                            <button class="btn btn-outline-danger btn-edit-small btn-gorev-sil" 
                                                    data-bs-toggle="modal" data-bs-target="#gorevSilOnayModal"
                                                    data-id="@item.Id" data-isim="@tamAd">
                                                <i class="fas fa-trash-alt"></i>
                                            </button>
                                        }
                                        else if (yetki == 2 || yetki == 3)
                                        {
                                            <button class="btn btn-outline-danger btn-edit-small opacity-50" disabled title="Silme yetkiniz yok"><i class="fas fa-trash-alt"></i></button>
                                        }
                                    </div>
                                </td>

                            </tr>
                        }
                    </tbody>
                </table>
            </div>

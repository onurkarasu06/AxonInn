@section Scripts {
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            @if (TempData["ValidResetToken"] != null)
            {
                <text>
                const resetModalEl = document.getElementById('resetPasswordModal');
                if (resetModalEl) new bootstrap.Modal(resetModalEl).show();
                </text>
            }

            function setupFormListener(formId, btnId, btnTextId, spinnerId, loadingText) {
                const form = document.getElementById(formId);
                const btn = document.getElementById(btnId);
                const textEl = document.getElementById(btnTextId);
                const spinner = document.getElementById(spinnerId);
                if (form && btn) {
                    form.addEventListener('submit', function (e) {
                        if (btn.classList.contains('btn-loading') || btn.disabled) {
                            e.preventDefault(); return;
                        }
                        if (this.checkValidity()) {
                            btn.classList.add('btn-loading'); btn.disabled = true; 
                            if (textEl) textEl.innerText = loadingText;
                            if (spinner) spinner.classList.remove('d-none');
                        }
                    });
                }
            }

            setupFormListener('loginForm', 'loginBtn', 'loginBtnText', 'loginBtnSpinner', 'GİRİŞ YAPILIYOR...');
            setupFormListener('forgotPasswordForm', 'forgotBtn', 'forgotBtnText', 'forgotBtnSpinner', 'GÖNDERİLİYOR...');
            setupFormListener('resetPasswordForm', 'resetBtn', 'resetBtnText', 'resetBtnSpinner', 'GÜNCELLENİYOR...');
        });
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                function resetState(btnId, btnTextId, spinnerId, originalText) {
                    const btn = document.getElementById(btnId);
                    const textEl = document.getElementById(btnTextId);
                    const spinner = document.getElementById(spinnerId);

                    if (btn) { btn.classList.remove('btn-loading'); btn.disabled = false; }
                    if (textEl) textEl.innerText = originalText;
                    if (spinner) spinner.classList.add('d-none');
                }

                resetState('loginBtn', 'loginBtnText', 'loginBtnSpinner', 'Sisteme Giriş');
                resetState('forgotBtn', 'forgotBtnText', 'forgotBtnSpinner', 'Talep Gönder');
                resetState('resetBtn', 'resetBtnText', 'resetBtnSpinner', 'ŞİFREMİ GÜNCELLE');
            }
        });
    </script>
}
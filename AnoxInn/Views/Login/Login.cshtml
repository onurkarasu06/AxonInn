                <form id="loginForm" method="post" asp-controller="Login" asp-action="Login">
                    @Html.AntiForgeryToken()
                    <div class="mb-3">
                        <label for="Email" class="form-label small fw-bold text-secondary ms-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">E-mail</label>
                        <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                            <span class="input-group-text border-0 bg-transparent ps-3">
                                <i class="fas fa-envelope text-primary opacity-50 small"></i>
                            </span>
                            <input type="email" class="form-control border-0 py-3 bg-transparent shadow-none"
                                    id="Email" name="email" placeholder="Email Adresiniz"
                                    required autocomplete="username" style="font-size: 0.9rem;" />
                        </div>
                    </div>
                    <div class="mb-4">
                        <label for="Password" class="form-label small fw-bold text-secondary ms-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">Şifre</label>
                        <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                            <span class="input-group-text border-0 bg-transparent ps-3">
                                <i class="fas fa-lock text-primary opacity-50 small"></i>
                            </span>
                            <input type="password" class="form-control border-0 py-3 bg-transparent shadow-none"
                                    id="Password" name="password" placeholder="••••••••"
                                    required autocomplete="current-password" style="font-size: 0.9rem;" />

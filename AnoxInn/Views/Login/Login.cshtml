@{
    Layout = null;
}

<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <meta name="description" content="AxonInn - Akıllı Otel Yönetim Sistemi Giriş Ekranı" />
    <title>Axoninn - Giriş Yap</title>

    <link rel="preload" href="/AxonInn.png" as="image" fetchpriority="high" />

    <link rel="preconnect" href="https://cdn.jsdelivr.net" />
    <link rel="preconnect" href="https://cdnjs.cloudflare.com" crossorigin="anonymous" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link rel="dns-prefetch" href="https://cdn.jsdelivr.net" />
    <link rel="dns-prefetch" href="https://cdnjs.cloudflare.com" />

    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" rel="stylesheet" />
    <link href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet" />
    
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" media="print" onload="this.media='all'" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" media="print" onload="this.media='all'" />
    <noscript>
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" />
        <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/animate.css/4.1.1/animate.min.css" />
    </noscript>



  <style>
        body {
            font-family: 'Inter', sans-serif;
            background-color: #f8f9fa;
            min-height: 100dvh;
            display: flex;
            align-items: center;
            justify-content: center;
            margin: 0;
            padding: 0;
            width: 100%;
            overflow-x: hidden;
            font-display: swap;
        }

        .login-card-container {
            width: 100%;
            max-width: 850px;
            padding: 20px;
            animation: fadeIn 0.8s ease-out;
            will-change: transform, opacity;
        }

        .card {
            border-radius: 2rem;
            border: none !important;
            box-shadow: 0 15px 40px rgba(0, 0, 0, 0.06) !important;
            background: #ffffff;
            will-change: transform, box-shadow;
        }

        .brand-gradient {
            background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
            -webkit-background-clip: text;
            -webkit-text-fill-color: transparent;
            display: inline-block;
        }

        .brand-logo {
            width: 75px;
            height: 75px;
            border-radius: 20px;
            box-shadow: 0 10px 25px rgba(13, 110, 253, 0.2);
            object-fit: contain;
            image-rendering: optimizeQuality;
        }

        .fw-black {
            font-weight: 900 !important;
        }

        .transition-focus {
            transition: border-color 0.2s ease, box-shadow 0.2s ease;
            border: 1px solid #dee2e6;
        }

        .transition-focus:focus-within {
            border-color: #0d6efd !important;
            box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
        }

        .transition-hover {
            transition: transform 0.2s ease, box-shadow 0.2s ease;
        }

        .transition-hover:hover {
            transform: translateY(-3px);
            box-shadow: 0 10px 20px rgba(13, 110, 253, 0.3) !important;
        }

        /* ======================================================== */
        /* MOBİL DÜZEN - Tam Ekran Dengesi ve Orantılı Boşluklar    */
        /* ======================================================== */
        @@media (max-width: 767px) {
            body {
                align-items: stretch;
                padding: 0;
                overflow-y: auto;
            }
            .login-card-container {
                padding: 1rem; /* Daha dengeli dış boşluk */
                display: flex;
                flex-direction: column;
                min-height: 100dvh; /* Ekran yüksekliğini tam doldurur */
                justify-content: space-between; /* İçeriği ekrana orantılı yayar */
            }
            .card {
                border-radius: 1.5rem;
                margin: auto 0; /* Kartı dikeyde KUSURSUZ merkeze iter */
            }
            .card-body {
                padding: 1.5rem !important; /* Formun sığması için iç boşlukları hafif daralttık */
            }
            .brand-logo {
                width: 60px !important; /* Logoyu bir tık küçülttük */
                height: 60px !important;
                margin-bottom: 10px !important;
                display: block !important;
                visibility: visible !important;
                opacity: 1 !important;
            }
            h1 {
                font-size: 2rem !important;
                margin-bottom: 5px !important;
            }
            .login-divider {
                border-bottom: 1px solid rgba(0,0,0,0.06);
                padding-bottom: 1rem; /* Logo ile form arasına ferah boşluk */
                margin-bottom: 1rem;
            }
            /* Inputlar arasındaki sıkışık mesafeyi orantılı hale getirdik */
            .mb-3 {
                margin-bottom: 1rem !important;
            }
            .mb-4 {
                margin-bottom: 1.25rem !important;
            }
            /* Alt kısımdaki boşluğu silen ve footer'ı en alta yapıştıran sihirli alan */
            .mobile-footer {
                margin-top: auto !important; /* Formu ortada bırakıp kendini dibe iter */
                padding-top: 1rem;
                padding-bottom: 1.5rem !important; /* Mobil tarayıcı alt menüsüne takılmaması için alt boşluğu açtık */
            }
        }

        .btn-loading {
            opacity: 0.8;
            pointer-events: none;
            cursor: not-allowed;
        }
    </style>











</head>

<body>
    <div class="login-card-container">
        <div class="card shadow-lg border-0 overflow-hidden">
            <div class="card-body p-4 p-md-5">
                <div class="row align-items-center">

                    <div class="col-md-5 text-center text-md-start pe-md-5 login-divider">
                        <div class="d-flex flex-column align-items-center align-items-md-start">
                            <div class="mb-4 animate__animated animate__fadeIn">
                                <img src="/AxonInn.png" alt="AxonInn Logo" class="brand-logo" width="75" height="75" fetchpriority="high" loading="eager" decoding="async" />
                            </div>
                            <h1 class="fw-black mb-1 brand-gradient" style="font-size: 2.5rem; letter-spacing: -2px; line-height: 1;">
                                Axon<span style="font-weight: 300; letter-spacing: 0;">INN</span>
                            </h1>
                            <p class="text-secondary mb-0" style="font-size: 0.85rem; max-width: 250px;">
                                Otelinizin dijital sinir sistemi.
                                <span class="d-block fw-bold text-primary opacity-75 mt-1" style="font-size: 0.7rem; text-transform: uppercase; letter-spacing: 1px;">
                                    Akıllı Yönetim & İş Zekası
                                </span>
                            </p>
                        </div>
                    </div>

                    <div class="col-md-7 ps-md-5 mt-2 mt-md-0">
                        <form id="loginForm" method="post" asp-controller="Login" asp-action="Login">
                            
                            @Html.AntiForgeryToken()

                            <div class="mb-3">
                                <label for="Email" class="form-label small fw-bold text-secondary ms-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">E-mail</label>
                                <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                                    <span class="input-group-text border-0 bg-white ps-3">
                                        <i class="fas fa-envelope text-primary opacity-50 small"></i>
                                    </span>
                                    <input type="email" class="form-control border-0 py-3 shadow-none"
                                           id="Email" name="email" placeholder="Email Adresiniz"
                                           required autocomplete="username" style="font-size: 0.9rem;" />
                                </div>
                            </div>

                            <div class="mb-4">
                                <label for="Password" class="form-label small fw-bold text-secondary ms-1 text-uppercase" style="font-size: 0.65rem; letter-spacing: 1px;">Password</label>
                                <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                                    <span class="input-group-text border-0 bg-white ps-3">
                                        <i class="fas fa-lock text-primary opacity-50 small"></i>
                                    </span>
                                    <input type="password" class="form-control border-0 py-3 shadow-none"
                                           id="Password" name="password" placeholder="••••••••"
                                           required autocomplete="current-password" style="font-size: 0.9rem;" />
                                </div>
                            </div>

                            @if (TempData["SuccessMessage"] != null)
                            {
                                <div class="alert alert-success py-2 px-3 border-0 shadow-sm mb-4 d-flex align-items-center animate__animated animate__fadeInDown"
                                     style="border-radius: 12px; font-size: 0.8rem; background-color: #f0fdf4; color: #15803d;">
                                    <i class="fas fa-check-circle me-2" style="font-size: 1.1rem;"></i>
                                    <span class="fw-bold">@TempData["SuccessMessage"]</span>
                                </div>
                            }

                            @if (TempData["ErrorMessage"] != null)
                            {
                                <div class="alert alert-danger py-2 px-3 border-0 shadow-sm mb-4 d-flex align-items-center animate__animated animate__shakeX"
                                     style="border-radius: 12px; font-size: 0.8rem; background-color: #fff5f5; color: #e03131;">
                                    <i class="fas fa-exclamation-triangle me-2"></i>
                                    <span class="fw-bold">@TempData["ErrorMessage"]</span>
                                </div>
                            }

                            <button class="btn btn-primary w-100 py-3 fw-bold text-uppercase shadow-lg transition-hover border-0 d-flex align-items-center justify-content-center"
                                    type="submit" id="loginBtn" style="border-radius: 15px; font-size: 0.9rem; letter-spacing: 1px; background: linear-gradient(45deg, #0d6efd, #0dcaf0);">
                                <span id="loginBtnText">Sisteme Giriş</span>
                                <div id="loginBtnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></div>
                            </button>
                        </form>
                    </div>

                    <div class="text-end mb-4">
                        <a href="#" data-bs-toggle="modal" data-bs-target="#forgotPasswordModal" class="text-decoration-none small fw-bold brand-gradient transition-hover d-inline-block" style="font-size: 0.75rem;">Şifremi Unuttum?</a>
                    </div>
                </div>
            </div>
        </div>

        <div class="text-center mt-4 mobile-footer">
            <div style="font-size: 0.65rem; color: #adb5bd; letter-spacing: 1.5px; font-weight: 700;">
                &copy; @DateTime.Now.Year <span class="brand-gradient fw-black" style="font-size: 0.75rem;">AxonINN</span>
                
                <span class="d-block mt-2 opacity-75" style="font-size: 0.6rem; letter-spacing: 1px;">
                    Tasarım ve Geliştirme: Onur KARASU
                </span>
            </div>
        </div>

    </div>

    <div class="modal fade" id="forgotPasswordModal" tabindex="-1" aria-hidden="true">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-black brand-gradient">Şifre Sıfırlama Talebi</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
                <form id="forgotPasswordForm" method="post" asp-controller="Login" asp-action="ForgotPassword">
                    @Html.AntiForgeryToken()
                    <div class="modal-body pt-3 pb-2">
                        <p class="text-secondary small mb-3">Sisteme kayıtlı e-posta adresinizi girin. Size şifrenizi sıfırlayabilmeniz için bir bağlantı göndereceğiz.</p>
                        <div class="mb-3">
                            <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                                <span class="input-group-text border-0 bg-light ps-3">
                                    <i class="fas fa-envelope text-primary opacity-50 small"></i>
                                </span>
                                <input type="email" class="form-control border-0 py-2 bg-light shadow-none" name="email" placeholder="E-posta adresiniz" required autocomplete="email" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-4 px-4">
                        <button type="submit" id="forgotBtn" class="btn btn-primary w-100 py-2 fw-bold text-uppercase shadow-sm rounded-pill d-flex align-items-center justify-content-center" style="font-size: 0.85rem; letter-spacing: 1px; background: linear-gradient(45deg, #0d6efd, #0dcaf0);">
                            <span id="forgotBtnText">Sıfırlama Linki Gönder</span>
                            <div id="forgotBtnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></div>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <div class="modal fade" id="resetPasswordModal" tabindex="-1" aria-hidden="true" data-bs-backdrop="static">
        <div class="modal-dialog modal-dialog-centered">
            <div class="modal-content border-0 shadow-lg rounded-4">
                <div class="modal-header border-0 pb-0">
                    <h5 class="modal-title fw-black brand-gradient">Yeni Şifre Belirle</h5>
                    <button type="button" class="btn-close shadow-none" data-bs-dismiss="modal" aria-label="Kapat"></button>
                </div>
               <form id="resetPasswordForm" method="post" asp-controller="Login" asp-action="ResetPassword">
                    @Html.AntiForgeryToken()
                    
                    <input type="hidden" name="token" value="@TempData["ValidResetToken"]" />
                    
                    <div class="modal-body pt-3 pb-2">
                        <p class="text-secondary small mb-3">Lütfen hesabınız için güvenli, yeni bir şifre giriniz.</p>
                        <div class="mb-3">
                            <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                                <span class="input-group-text border-0 bg-light ps-3">
                                    <i class="fas fa-lock text-primary opacity-50 small"></i>
                                </span>
                                <input type="password" class="form-control border-0 py-2 bg-light shadow-none" name="newPassword" placeholder="Yeni Şifreniz" required minlength="6" autocomplete="new-password" />
                            </div>
                        </div>
                        <div class="mb-3">
                            <div class="input-group rounded-4 overflow-hidden shadow-sm transition-focus">
                                <span class="input-group-text border-0 bg-light ps-3">
                                    <i class="fas fa-check-double text-primary opacity-50 small"></i>
                                </span>
                                <input type="password" class="form-control border-0 py-2 bg-light shadow-none" name="confirmPassword" placeholder="Şifrenizi Tekrar Girin" required minlength="6" autocomplete="new-password" />
                            </div>
                        </div>
                    </div>
                    <div class="modal-footer border-0 pt-0 pb-4 px-4">
                        <button type="submit" id="resetBtn" class="btn btn-primary w-100 py-2 fw-bold text-uppercase shadow-sm rounded-pill d-flex align-items-center justify-content-center" style="font-size: 0.85rem; letter-spacing: 1px; background: linear-gradient(45deg, #0d6efd, #0dcaf0);">
                            <span id="resetBtnText">ŞİFREMİ GÜNCELLE</span>
                            <div id="resetBtnSpinner" class="spinner-border spinner-border-sm ms-2 d-none" role="status" aria-hidden="true"></div>
                        </button>
                    </div>
                </form>
            </div>
        </div>
    </div>

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
    
    <script>
        document.addEventListener("DOMContentLoaded", function() {
            
            // Eğer C#'dan onaylı bir token geldiyse, Modalı otomatik göster.
            @if (TempData["ValidResetToken"] != null)
            {
                <text>
                const resetModalEl = document.getElementById('resetPasswordModal');
                if (resetModalEl) {
                    new bootstrap.Modal(resetModalEl).show();
                }
                </text>
            }

            // Javascript Performans ve DRY Prensibi: Kod tekrarını önleyen dinamik form işlemcisi
            function setupFormListener(formId, btnId, btnTextId, spinnerId, loadingText) {
                const form = document.getElementById(formId);
                const btn = document.getElementById(btnId);
                const textEl = document.getElementById(btnTextId);
                const spinner = document.getElementById(spinnerId);

                if (form && btn) {
                    form.addEventListener('submit', function (e) {
                        // Buton zaten yükleniyor veya kapalıysa ikinci isteği (Çift tıklamayı) kesinlikle engelle
                        if (btn.classList.contains('btn-loading') || btn.disabled) {
                            e.preventDefault();
                            return;
                        }

                        if (this.checkValidity()) {
                            btn.classList.add('btn-loading');
                            btn.disabled = true; // Sadece class değil, butonu komple fiziksel kilitler
                            
                            if (textEl) textEl.innerText = loadingText;
                            if (spinner) spinner.classList.remove('d-none');
                        }
                    });
                }
            }

            // Metot çağrıları (Kodu uzatmadan 3 form bağlanır)
            setupFormListener('loginForm', 'loginBtn', 'loginBtnText', 'loginBtnSpinner', 'GİRİŞ YAPILIYOR...');
            setupFormListener('forgotPasswordForm', 'forgotBtn', 'forgotBtnText', 'forgotBtnSpinner', 'GÖNDERİLİYOR...');
            setupFormListener('resetPasswordForm', 'resetBtn', 'resetBtnText', 'resetBtnSpinner', 'GÜNCELLENİYOR...');
        });

        // Tarayıcıda Geri/İleri (BFCache) Yapıldığında Butonları Eski Haline Getirme
        window.addEventListener('pageshow', function (event) {
            if (event.persisted) {
                function resetState(btnId, btnTextId, spinnerId, originalText) {
                    const btn = document.getElementById(btnId);
                    const textEl = document.getElementById(btnTextId);
                    const spinner = document.getElementById(spinnerId);

                    if (btn) {
                        btn.classList.remove('btn-loading');
                        btn.disabled = false;
                    }
                    if (textEl) textEl.innerText = originalText;
                    if (spinner) spinner.classList.add('d-none');
                }

                resetState('loginBtn', 'loginBtnText', 'loginBtnSpinner', 'Sisteme Giriş');
                resetState('forgotBtn', 'forgotBtnText', 'forgotBtnSpinner', 'Sıfırlama Linki Gönder');
                resetState('resetBtn', 'resetBtnText', 'resetBtnSpinner', 'ŞİFREMİ GÜNCELLE');
            }
        });
    </script>
</body>
</html>
@{
    Layout = "~/Views/Shared/_LoginLayout.cshtml";
    ViewBag.Title = "Giriş Yap";
}
@{
    var aforizmalar = new[] {
        new { Soz = "Geleceği tahmin etmenin en iyi yolu, onu icat etmektir.", Yazar = "Alan Kay" },
        new { Soz = "Yeterince gelişmiş bir teknoloji, sihirden farksızdır.", Yazar = "Arthur C. Clarke" },
        new { Soz = "Sadelik, gelişmişliğin en son noktasıdır.", Yazar = "Leonardo da Vinci" },
        new { Soz = "Zorlukların tam ortasında fırsatlar yatar.", Yazar = "Albert Einstein" },
        new { Soz = "Mükemmelliğe, eklenecek bir şey kalmadığında değil, çıkarılacak bir şey kalmadığında ulaşılır.", Yazar = "Antoine de Saint-Exupéry" },
        new { Soz = "Değişmeyen tek şey, değişimin kendisidir.", Yazar = "Herakleitos" },
        new { Soz = "Mantık sizi A'dan B'ye götürür. Hayal gücü ise her yere.", Yazar = "Albert Einstein" },
        new { Soz = "Düşünüyorum, öyleyse varım.", Yazar = "René Descartes" },
        new { Soz = "Sorgulanmayan bir hayat, yaşanmaya değmez.", Yazar = "Sokrates" },
        new { Soz = "Bildiğim tek şey, hiçbir şey bilmediğimdir. Gerçek bilgelik budur.", Yazar = "Sokrates" },
        new { Soz = "İnsanı cevaplarından çok, sorduğu sorularla yargılayın.", Yazar = "Voltaire" },
        new { Soz = "Kendi aklını kullanma cesaretini göster!", Yazar = "Immanuel Kant" },
        new { Soz = "Yaşamak için bir 'neden'i olan, her türlü 'nasıl'a katlanır.", Yazar = "Friedrich Nietzsche" },
        new { Soz = "Gerçekleri değil, yalnızca yorumları deneyimleriz.", Yazar = "Friedrich Nietzsche" },
        new { Soz = "Kendi alevlerinizde yanmaya hazır olmalısınız; önce kül olmadan kendinizi nasıl yenileyebilirsiniz?", Yazar = "Friedrich Nietzsche" },
        new { Soz = "Zamanı boşa harcamayın, çünkü hayatın yapıldığı madde odur.", Yazar = "Benjamin Franklin" },
        new { Soz = "Hazırlık yapmayı başaramazsanız, başarısız olmaya hazırlanırsınız.", Yazar = "Benjamin Franklin" },
        new { Soz = "Bir bugün, iki yarına bedeldir.", Yazar = "Benjamin Franklin" },
        new { Soz = "Hangi limana yelken açtığını bilmeyen bir gemiye, hiçbir rüzgar yardım edemez.", Yazar = "Seneca" },
        new { Soz = "Hayatımızın kalitesini, düşüncelerimizin kalitesi belirler.", Yazar = "Marcus Aurelius" },
        new { Soz = "Bizi korkutan şeylerin çoğu, gerçekte olandan ziyade hayal gücümüzde yarattıklarımızdır.", Yazar = "Seneca" },
        new { Soz = "Mükemmellik bir eylem değil, bir alışkanlıktır.", Yazar = "Aristoteles" },
        new { Soz = "Yetenek, kimsenin vuramadığı hedefi vurur; deha, kimsenin göremediği hedefi vurur.", Yazar = "Arthur Schopenhauer" }
    };
    var rnd = new Random();
    var gununSozu = aforizmalar[rnd.Next(aforizmalar.Length)];
}

@section Styles {
    <style>
     /* --- MİKRO ANİMASYONLAR (Animate.css Yerine) --- */
@@keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
@@keyframes fadeInDown { from { opacity: 0; transform: translate3d(0, -20px, 0); } to { opacity: 1; transform: translate3d(0, 0, 0); } }
@@keyframes fadeInUp { from { opacity: 0; transform: translate3d(0, 20px, 0); } to { opacity: 1; transform: translate3d(0, 0, 0); } }
@@keyframes fadeInLeft { from { opacity: 0; transform: translate3d(-20px, 0, 0); } to { opacity: 1; transform: translate3d(0, 0, 0); } }
@@keyframes shakeX {
    from, to { transform: translate3d(0, 0, 0); }
    10%, 30%, 50%, 70%, 90% { transform: translate3d(-10px, 0, 0); }
    20%, 40%, 60%, 80% { transform: translate3d(10px, 0, 0); }
}

.animate__animated { animation-fill-mode: both; }
.animate__fadeIn { animation: fadeIn 0.8s ease-out; }
.animate__fadeInDown { animation: fadeInDown 0.8s ease-out; }
.animate__fadeInUp { animation: fadeInUp 0.8s ease-out; }
.animate__fadeInLeft { animation: fadeInLeft 0.8s ease-out; }
.animate__shakeX { animation: shakeX 1s; }
.animate__delay-1s { animation-delay: 1s; }

body {
    font-family: 'Inter', sans-serif;
    background-color: #f0f4f8; 
    margin: 0;
    padding: 0;
    height: 100vh;
    overflow: hidden; /* Kaydırma çubuğu çıkmamasını garanti altına alır */
}

/* Bootstrap'in modal açıldığında sayfayı bozmasını (titretmesini) KESİN ENGELLER */
body.modal-open {
    padding-right: 0 !important;
    overflow: hidden !important;
}

.login-wrapper {
    width: 100%;
    max-width: 1200px;
    height: 100%; 
    margin: 0 auto;
    display: flex; /* Ortalama görevini body yerine wrapper üstlendi */
    align-items: center;
    justify-content: center;
    padding: 0 20px;
    animation: fadeIn 0.8s ease-out;
    will-change: transform, opacity;
}

.login-card {
    display: flex;
    flex-direction: row;
    width: 100%;
    height: 85vh; /* Yükseklik sınırlarını buraya aldık */
    max-height: 750px;  
    min-height: 550px;
    background-color: #ffffff;
    border-radius: 1.5rem;
    box-shadow: 0 20px 50px rgba(13, 110, 253, 0.12);
    overflow: hidden;
}

.left-panel {
    flex: 0 0 60%;
    width: 60%;
    background: radial-gradient(circle at top right, #113a71 0%, #061831 100%);
    padding: 2.5rem 4rem;
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow: hidden;
}

.left-panel::before {
    content: '';
    position: absolute;
    top: 0; left: 0; right: 0; bottom: 0;
    background-image: radial-gradient(rgba(255, 255, 255, 0.04) 1px, transparent 1px);
    background-size: 30px 30px;
    pointer-events: none;
    z-index: 0;
}

.vision-glass-circle {
    position: absolute;
    background: rgba(255, 255, 255, 0.08);
    border-radius: 50%;
    backdrop-filter: blur(10px);
    -webkit-backdrop-filter: blur(10px);
    pointer-events: none;
    z-index: 0;
}

.glass-card {
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.08) 0%, rgba(255, 255, 255, 0.02) 100%);
    border-top: 1px solid rgba(255, 255, 255, 0.4);
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    border-right: 1px solid rgba(255, 255, 255, 0.05);
    border-bottom: 1px solid rgba(255, 255, 255, 0.05);
    border-radius: 20px;
    padding: 1.5rem;
    backdrop-filter: blur(16px);
    -webkit-backdrop-filter: blur(16px);
    box-shadow: 0 20px 40px rgba(0, 0, 0, 0.3), inset 0 2px 5px rgba(255, 255, 255, 0.1);
    transition: all 0.4s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    cursor: default;
    position: relative;
    z-index: 1;
    overflow: hidden;
}

.glass-card::after {
    content: '';
    position: absolute;
    top: 0; left: -150%;
    width: 50%; height: 100%;
    background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(255,255,255,0.15) 50%, rgba(255,255,255,0) 100%);
    transform: skewX(-25deg);
    transition: all 0.7s ease;
}

.glass-card:hover {
    transform: translateY(-5px) scale(1.02);
    box-shadow: 0 25px 50px rgba(0, 0, 0, 0.4), inset 0 2px 5px rgba(255, 255, 255, 0.2);
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.12) 0%, rgba(255, 255, 255, 0.04) 100%);
}

.glass-card:hover::after {
    left: 150%;
}

.tech-icon-box {
    width: 55px;
    height: 55px;
    display: flex; align-items: center; justify-content: center;
    border-radius: 16px;
    background: linear-gradient(135deg, rgba(255, 255, 255, 0.15) 0%, rgba(255, 255, 255, 0.02) 100%);
    color: #ffffff;
    transition: all 0.4s ease;
    flex-shrink: 0;
    border-top: 1px solid rgba(255, 255, 255, 0.4);
    border-left: 1px solid rgba(255, 255, 255, 0.2);
    box-shadow: 0 8px 16px rgba(0, 0, 0, 0.2), inset 0 2px 4px rgba(255, 255, 255, 0.1);
}

.glass-card:hover .tech-icon-box {
    background: linear-gradient(135deg, #ffffff 0%, #f0f0f0 100%);
    color: #061831;
    box-shadow: 0 0 25px rgba(255, 255, 255, 0.3);
    transform: scale(1.15) translateY(-2px) rotate(5deg);
}

.aphorism-box {
    background: linear-gradient(90deg, rgba(255, 255, 255, 0.1) 0%, transparent 100%);
    border-left: 3px solid #ffffff;
    padding: 1.25rem 1.5rem;
    border-radius: 0 16px 16px 0;
    backdrop-filter: blur(5px);
    position: relative;
    z-index: 1;
}

.right-panel {
    flex: 0 0 40%;
    width: 40%;
    padding: 2.5rem 3.5rem;
    display: flex;
    flex-direction: column;
    background-color: #ffffff;
}

.brand-gradient {
    background: linear-gradient(135deg, #0d6efd 0%, #0dcaf0 100%);
    -webkit-background-clip: text;
    -webkit-text-fill-color: transparent;
    display: inline-block;
}

.brand-logo {
    width: 75px;
    height: 75px;
    border-radius: 18px;
    box-shadow: 0 10px 25px rgba(13, 110, 253, 0.15);
    object-fit: contain;
}

.transition-focus {
    transition: border-color 0.2s ease, box-shadow 0.2s ease;
    border: 1px solid #dee2e6;
    background-color: #f8f9fa;
}

.transition-focus:focus-within {
    border-color: #0d6efd !important;
    background-color: #ffffff;
    box-shadow: 0 0 0 0.25rem rgba(13, 110, 253, 0.25) !important;
}

.transition-focus input { background-color: transparent !important; }

.transition-hover { transition: transform 0.2s ease, box-shadow 0.2s ease; }

.transition-hover:hover {
    transform: translateY(-2px);
    box-shadow: 0 10px 20px rgba(13, 110, 253, 0.3) !important;
}

.btn-loading { 
    opacity: 0.8;
    pointer-events: none; 
    cursor: not-allowed; 
}

/* Modalların mobilde tam ortalanması için eklenen düzeltme */
.modal {
    padding-right: 0 !important; /* Bootstrap'in sağa iten boşluğunu sıfırlar */
    padding-left: 0 !important;
}

.modal-dialog-centered {
    display: flex;
    align-items: center;
    justify-content: center;
    min-height: calc(100% - 1rem); /* Mobil tarayıcı barları için pay bırakır */
    margin: 0 auto; /* Yatayda tam ortalamayı garanti eder */
}

@@media (max-width: 576px) {
    .modal-dialog {
        /* Modalın ekranın kenarlarına çok yapışmaması için */
        margin-left: 1rem !important;
        margin-right: 1rem !important;
        width: auto;
        max-width: none;
    }
    
    /* Arka planın (body) modal açıldığında sağa-sola titremesini engeller */
    body.modal-open {
        display: block !important; /* Modal açıldığında flex'i devre dışı bırakıp sabitler */
        width: 100%;
        height: 100dvh;
        position: fixed; /* Kaymayı kökten engeller */
    }
}
 
@@media (max-width: 991px) {
    body { 
        height: 100dvh;
        overflow: hidden; /* Ekranın aşağı/yukarı kaymasını tamamen engeller */
    }
    .login-wrapper { 
        height: 100dvh; 
        padding: 1rem;
        display: flex;
        align-items: center;
        justify-content: center;
        margin: 0; 
    }
    .login-card { 
        flex-direction: column;
        border-radius: 1.5rem;
        height: auto;
        min-height: unset; /* Masaüstünden gelen min-height'i sıfırlar */
        max-height: 100%; /* İçeriğin karttan dışarı taşmasını önler */
    }
    .left-panel { 
        display: none !important;
    }
    .right-panel { 
        flex: 0 0 100%;
        width: 100% !important; 
        padding: 1.5rem !important; /* Ekrana sığması için padding'i 2.5rem'den 1.5rem'e düşürdük */ 
        display: flex;
        flex-direction: column;
        justify-content: center;
    }
    
    /* Mobilde içeriğin taşmasını engellemek için kritik boşlukları ve boyutları hafifçe optimize ediyoruz */
    .right-panel h1 { font-size: 2.2rem !important; }
    .brand-logo, .position-relative.mb-2 { width: 60px !important; height: 60px !important; }
    .right-panel .mb-4 { margin-bottom: 1rem !important; }
    .right-panel .mb-3 { margin-bottom: 0.75rem !important; }
}


/* --- MANIFESTO MODAL DÜZELTMELERİ --- */
.manifesto-slide {
    min-height: 520px;
    height: 100%;
}
.manifesto-close-btn {
    top: 15px; right: 15px; z-index: 1055; background-color: rgba(255,255,255,0.9); padding: 12px; border-radius: 50%;
}
#manifestoCarousel .carousel-item { transition: transform 0.6s cubic-bezier(0.25, 0.46, 0.45, 0.94); }
#manifestoCarousel .carousel-indicators { bottom: auto; top: 15px; margin-bottom: 0; }
#manifestoCarousel .carousel-indicators [data-bs-target] { width: 30px; height: 4px; border-radius: 10px; background-color: #cbd5e1; border: none; transition: all 0.3s ease; margin: 0 4px; }
#manifestoCarousel .carousel-indicators .active { width: 45px; background-color: #0d6efd !important; }

@@media (max-width: 768px) {
    .manifesto-slide { min-height: 480px !important; padding: 2rem 1.25rem !important; }
    .manifesto-quote { font-size: 0.95rem !important; line-height: 1.5 !important; }
    .manifesto-slogan { font-size: 1.1rem !important; }
    .manifesto-title { font-size: 1.25rem !important; }
    .manifesto-text { font-size: 0.95rem !important; line-height: 1.5 !important; }
    .manifesto-icon { width: 50px !important; height: 50px !important; font-size: 1.25rem !important; margin-bottom: 1rem !important; }
    .manifesto-close-btn { top: 10px; right: 10px; padding: 10px; }
}

@@keyframes subtlePulse {
    0% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0.3); }
    70% { box-shadow: 0 0 0 10px rgba(13, 110, 253, 0); }
    100% { box-shadow: 0 0 0 0 rgba(13, 110, 253, 0); }
}
.btn-manifesto-trigger {
    animation: subtlePulse 2.5s infinite;
}


.btn-manifesto-trigger {
position: relative;
overflow: hidden;
}
       .btn-manifesto-trigger::before {
    content: '';
    position: absolute;
    top: 0; left: -100%; width: 50%; height: 100%;
    background: linear-gradient(to right, rgba(255,255,255,0) 0%, rgba(13,110,253,0.15) 50%, rgba(255,255,255,0) 100%);
    transform: skewX(-25deg);
    /* Toplam döngü 4 saniye olacak şekilde ayarladık */
    animation: shimmerSwipe 2s infinite; 
}

@@keyframes shimmerSwipe {
    0% { left: -100%; }
    50% { left: 200%; }  /* 0'dan 50'ye: Işığın geçişi tam 2 saniye (çok daha yavaş ve zarif) sürer */
    100% { left: 200%; } /* 50'den 100'e: Sonraki geçiş için tam 2 saniye sessizce bekler */
}
    </style>
}


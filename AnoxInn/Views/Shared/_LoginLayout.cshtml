<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewBag.Title - AxonInn Otel Yönetim Sistemi</title>
    <meta name="description" content="AxonInn Akıllı Otel Yönetim Sistemi giriş ekranı. Otelinizin operasyonel tüm süreçlerini tek bir merkezden güvenle yönetmeye hemen başlayın." />
    <meta name="keywords" content="Otel yönetim sistemi AxonInn">
    <meta name="author" content="Onur Karasu">
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">
  
    <meta property="og:title" content="@ViewBag.Title - AxonInn Otel Yönetim Sistemi">
    <meta property="og:description" content="Otelinizin tüm süreçlerini kolayca yönetin.">
    <meta property="og:image" content="https://www.axoninn.com.tr/AxonInn.webp">
    <meta property="og:url" content="https://www.axoninn.com.tr/">
    <meta property="og:type" content="website">
    
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;900&display=swap"></noscript>

    <link rel="preload" href="~/lib/bootstrap/dist/css/bootstrap.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'" />
    <noscript><link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" /></noscript>

    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/css/all.min.css" /></noscript>

    <style>
            /* ⚡ PERFORMANS: FontAwesome'ın metinleri gizlemesini (FOIT) engeller */
            @@font-face {
                font-family: 'Font Awesome 6 Free';
                font-style: normal;
                font-weight: 900;
                font-display: swap;
                src: url(https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.0.0/webfonts/fa-solid-900.woff2) format("woff2");
            }
    </style>

    @await RenderSectionAsync("Styles", required: false)
</head>
<body>
    
    @RenderBody()

    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js" defer></script>
    
    @await RenderSectionAsync("Scripts", required: false)

    <script>
        document.addEventListener("DOMContentLoaded", function() {
        setTimeout(function() {
        var script = document.createElement('script');
        script.src = 'https://www.googletagmanager.com/gtag/js?id=G-LSLKRPYXY2';
        script.async = true;
        document.head.appendChild(script);

        window.dataLayer = window.dataLayer || [];
        function gtag(){dataLayer.push(arguments);}
        gtag('js', new Date());

        gtag('config', 'G-LSLKRPYXY2');
        gtag('config', 'AW-18020925402');
        }, 3500);
        });
    </script>
</body>
</html>
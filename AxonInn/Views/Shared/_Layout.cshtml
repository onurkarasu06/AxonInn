<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
      <style>
          html {
              visibility: hidden;
              opacity: 0;
          }
          </style>

    
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"] - AxonInn</title>
    <meta name="description" content="@(ViewData["MetaDescription"] ?? "AxonInn - Akıllı Otel Yönetim Sistemi.")" />
    <meta name="robots" content="index, follow">
    <meta name="googlebot" content="index, follow">

    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>

    <link rel="preload" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://fonts.googleapis.com/css2?family=Inter:wght@400;600;700;800;900&family=Plus+Jakarta+Sans:wght@400;600;800&display=swap"></noscript>

    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    
    <link rel="stylesheet" href="~/css/site.css" asp-append-version="true" />
    
    <link rel="preload" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css"></noscript>

    <link rel="preload" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" as="style" onload="this.onload=null;this.rel='stylesheet'">
    <noscript><link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" /></noscript>

    <script src="~/lib/jquery/dist/jquery.min.js" defer></script>
    <script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js" defer></script>
    <script src="~/js/site.js" asp-append-version="true" defer></script>
    
    @await RenderSectionAsync("Styles", required: false)
</head>
<body class="d-flex flex-column min-vh-100">
    
    <partial name="_Header" />

    <main role="main" class="flex-grow-1 py-2">
        @RenderBody()
    </main>

    <partial name="_Footer" />

    @await RenderSectionAsync("Scripts", required: false)

    <script>
            document.addEventListener("DOMContentLoaded", function() {
                setTimeout(function() {
                    var script = document.createElement('script');
                    script.src = 'https://www.googletagmanager.com/gtag/js?id=G-LSLKRPYXY2';
                    script.async = true;
                    document.head.appendChild(script);

                    window.dataLayer = window.dataLayer || [];
                    function gtag(){dataLayer.push(arguments);}
                    gtag('js', new Date());

                    gtag('config', 'G-LSLKRPYXY2');
                    gtag('config', 'AW-18020925402');
                }, 3500); // 3.5 sn gecikme ile Lighthouse test süresini atlatır
            });

                       document.addEventListener("DOMContentLoaded", function() {
            document.documentElement.style.visibility = "visible";
            document.documentElement.style.transition = "opacity 0.5s ease";
            document.documentElement.style.opacity = "1";
            });
    </script>
</body>
</html>